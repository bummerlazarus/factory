# ============================================================
# Secrets — never commit
# ============================================================
.env
.env.*
!.env.example
!.env.template

# ============================================================
# Dashboard lives in its own repo (bummerlazarus/local-agents-dashboard)
# Clone it separately into ./dashboard/ to work on both together.
# ============================================================
dashboard/

# ============================================================
# External / cloned repos and reference material (~1.8GB)
# Not factory-authored; licensing varies; too big for git.
# ============================================================
reference/

# ============================================================
# macOS noise
# ============================================================
.DS_Store
._*

# ============================================================
# Editor / tooling
# ============================================================
.vscode/
*.swp
*.swo

# ============================================================
# Node (if any ad-hoc scripts appear at the factory root)
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================
# Python venvs (ops scripts)
# ============================================================
.venv/
venv/
__pycache__/
*.pyc

# ============================================================
# Supabase CLI temp state (if it appears)
# ============================================================
**/supabase/.temp/

# ============================================================
# Misc
# ============================================================
.DS_Store?
*.log
tmp/
