#!/usr/bin/env python3
"""
lab-ingest-pdf — convert a PDF to a `kind: paper` doc staged in inbox/proposed/.

Pipeline:
  1. Convert PDF → markdown (pymupdf4llm; marker pluggable later).
  2. Send a head+tail excerpt to Claude → bibliographic JSON.
  3. Stage:
       inbox/proposed/<slug>.md         (frontmatter + full converted body)
       inbox/raw/papers/<slug>.pdf      (cached PDF)
  4. Insert reference_docs row (lab_zone=inbox, status=draft, kind=paper).

Promotion is a separate human step:
  lab-promote <slug>

The promotion moves the .md to knowledge-atlas/documents/ and the .pdf to
knowledge-atlas/raw/papers/, updating frontmatter `source.pdf_path`.

Filesystem writes are staged in a tempdir; on any failure the staged files
are discarded and the Supabase row (if inserted) is deleted by slug.

Usage:
  lab-ingest-pdf <path/to/paper.pdf> [--domain <slug>] [--lab-root PATH] [--converter pymupdf4llm|marker]
"""

from __future__ import annotations
import os, sys
from pathlib import Path

# ---- auto-venv re-exec ----------------------------------------------------
# The lab keeps marker / pymupdf4llm / pyyaml in its own venv to avoid PEP 668
# conflicts with system Python. If we're not running under that venv, locate
# it and re-exec ourselves through it. Idempotent via sentinel env var.
_LAB_DEFAULT_ROOT = Path("/Users/edmundmitchell/Documents/Claude/Projects/EM Research Lab")
def _ensure_lab_venv() -> None:
    if os.environ.get("LAB_INGEST_PDF_REEXEC") == "1":
        return
    venv_dir = Path(os.environ.get("LAB_VENV") or (_LAB_DEFAULT_ROOT / ".venv"))
    venv_py = venv_dir / "bin" / "python3"
    if not venv_py.is_file():
        return
    # sys.prefix is the venv root when running under that venv; comparing
    # prefixes avoids the symlink-resolution trap where venv/bin/python3 ->
    # python3.14 -> /opt/homebrew/...python3.14 makes resolve() match system.
    if Path(sys.prefix) == venv_dir:
        return
    os.environ["LAB_INGEST_PDF_REEXEC"] = "1"
    os.execv(str(venv_py), [str(venv_py), __file__] + sys.argv[1:])
_ensure_lab_venv()

import argparse, json, re, shutil, tempfile, urllib.parse, urllib.request, urllib.error
from datetime import date, datetime, timezone

import yaml  # PyYAML

# ---- env loading ----------------------------------------------------------

ENV_PATH = Path(os.environ.get("FACTORY_ENV", "/Users/edmundmitchell/factory/ops/.env"))

def load_env() -> dict:
    if not ENV_PATH.exists():
        sys.exit(f"env file not found: {ENV_PATH}")
    env = {}
    for line in ENV_PATH.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        env[k.strip()] = v.strip().strip('"').strip("'")
    for required in ("SUPABASE_URL", "SUPABASE_SERVICE_ROLE_KEY", "ANTHROPIC_API_KEY"):
        if not env.get(required):
            sys.exit(f"missing required env: {required}")
    return env

# ---- HTTP -----------------------------------------------------------------

def http(method: str, url: str, headers: dict, body=None) -> tuple[int, bytes]:
    data = None
    if body is not None:
        data = body if isinstance(body, (bytes, bytearray)) else json.dumps(body).encode()
    req = urllib.request.Request(url, data=data, method=method, headers=headers)
    try:
        with urllib.request.urlopen(req) as resp:
            return resp.status, resp.read()
    except urllib.error.HTTPError as e:
        return e.code, e.read()

def sb_headers(env: dict) -> dict:
    return {
        "apikey": env["SUPABASE_SERVICE_ROLE_KEY"],
        "Authorization": f"Bearer {env['SUPABASE_SERVICE_ROLE_KEY']}",
        "Content-Type": "application/json",
    }

def insert_reference_doc(env: dict, row: dict) -> str:
    headers = {**sb_headers(env), "Prefer": "return=representation"}
    status, body = http("POST", f"{env['SUPABASE_URL']}/rest/v1/reference_docs",
                        headers, body=row)
    if status not in (200, 201):
        raise RuntimeError(f"reference_docs insert failed ({status}): {body[:500]!r}")
    return json.loads(body)[0]["id"]

def delete_reference_doc_by_slug(env: dict, slug: str) -> None:
    url = f"{env['SUPABASE_URL']}/rest/v1/reference_docs?slug=eq.{urllib.parse.quote(slug)}"
    http("DELETE", url, sb_headers(env))

# ---- Anthropic ------------------------------------------------------------

ANTHROPIC_MODEL = "claude-opus-4-7"

PROMPT_RE = re.compile(r"## Prompt\b.*?\n```[^\n]*\n(.*?)\n```", re.DOTALL)

def load_agent_prompt(lab_root: Path, agent_filename: str) -> str:
    path = lab_root / "research" / "04-agent-instructions" / agent_filename
    if not path.is_file():
        sys.exit(f"agent instructions not found: {path}")
    m = PROMPT_RE.search(path.read_text())
    if not m:
        sys.exit(f"no ## Prompt fenced block in {path}")
    return m.group(1)

def call_claude(env: dict, prompt: str) -> dict:
    body = {
        "model": ANTHROPIC_MODEL,
        "max_tokens": 16384,  # bumped from 4096 — TrustLLM-style papers with huge author lists overflowed
        "messages": [{"role": "user", "content": prompt}],
    }
    headers = {
        "x-api-key": env["ANTHROPIC_API_KEY"],
        "anthropic-version": "2023-06-01",
        "content-type": "application/json",
    }
    status, raw = http("POST", "https://api.anthropic.com/v1/messages", headers, body)
    if status != 200:
        sys.exit(f"anthropic call failed ({status}): {raw[:500]!r}")
    resp = json.loads(raw)
    text = "".join(b["text"] for b in resp["content"] if b["type"] == "text").strip()
    if text.startswith("```"):
        text = re.sub(r"^```(?:json)?\s*|\s*```$", "", text, flags=re.DOTALL)
    try:
        parsed = json.loads(text)
    except json.JSONDecodeError as e:
        sys.exit(f"claude returned non-JSON: {e}\n---\n{text[:800]}")
    if "error" in parsed:
        sys.exit(f"paper-reader agent declined: {parsed['error']}")
    return parsed

# ---- PDF conversion -------------------------------------------------------

def _pkg_version(name: str) -> str:
    try:
        return __import__("importlib.metadata", fromlist=["version"]).version(name)
    except Exception:
        return "unknown"

def _page_count(pdf_path: Path) -> int:
    import pymupdf
    doc = pymupdf.open(str(pdf_path))
    n = doc.page_count
    doc.close()
    return n

def _convert_pymupdf4llm(pdf_path: Path) -> tuple[str, str, str, int]:
    try:
        import pymupdf4llm
    except ImportError:
        sys.exit("pymupdf4llm not installed. Try: pip install pymupdf4llm")
    md = pymupdf4llm.to_markdown(str(pdf_path))
    return md, "pymupdf4llm", _pkg_version("pymupdf4llm"), _page_count(pdf_path)

def _convert_marker(pdf_path: Path) -> tuple[str, str, str, int]:
    try:
        from marker.converters.pdf import PdfConverter
        from marker.models import create_model_dict
        from marker.output import text_from_rendered
    except ImportError:
        sys.exit("marker-pdf not installed in this venv. Try: pip install marker-pdf")
    # First-run downloads model weights to ~/.cache. Subsequent runs are fast.
    converter = PdfConverter(
        artifact_dict=create_model_dict(),
        config={"output_format": "markdown"},
    )
    rendered = converter(str(pdf_path))
    text, _fmt, _images = text_from_rendered(rendered)
    return text, "marker", _pkg_version("marker-pdf"), _page_count(pdf_path)

def convert_pdf(pdf_path: Path, converter: str) -> tuple[str, str, str, int, list[str]]:
    """Return (markdown_body, tool_name, tool_version, page_count, warnings).

    For converter='marker', falls back to pymupdf4llm if marker raises and
    records a warning so the frontmatter reflects what actually ran.
    """
    warnings: list[str] = []
    if converter == "pymupdf4llm":
        md, tool, ver, pages = _convert_pymupdf4llm(pdf_path)
        warnings.append("pymupdf4llm retains running headers, page numbers, and may collapse multi-line TOC formatting")
        return md, tool, ver, pages, warnings
    if converter == "marker":
        try:
            md, tool, ver, pages = _convert_marker(pdf_path)
            return md, tool, ver, pages, warnings
        except Exception as e:
            print(f"  marker failed ({type(e).__name__}: {e}); falling back to pymupdf4llm", file=sys.stderr)
            md, tool, ver, pages = _convert_pymupdf4llm(pdf_path)
            warnings.append(f"marker conversion failed; fell back to pymupdf4llm. Reason: {type(e).__name__}: {e}")
            warnings.append("pymupdf4llm retains running headers, page numbers, and may collapse multi-line TOC formatting")
            return md, tool, ver, pages, warnings
    sys.exit(f"unknown converter: {converter}")

# ---- slug helpers ---------------------------------------------------------

SLUG_RE = re.compile(r"^[a-z0-9]+(?:-[a-z0-9]+)*$")

def validate_slug(slug: str) -> None:
    if not SLUG_RE.fullmatch(slug) or len(slug) > 60:
        sys.exit(f"invalid slug from agent: {slug!r}")

ARXIV_RE = re.compile(r"(\d{4}\.\d{4,5})")

def detect_arxiv_id_from_filename(filename: str) -> str | None:
    m = ARXIV_RE.search(filename)
    return m.group(1) if m else None

# ---- frontmatter rendering ------------------------------------------------

def build_frontmatter(meta: dict, slug: str, domain: str, today: str,
                      pdf_path_rel: str, conv_tool: str, conv_version: str,
                      pages: int, conv_warnings: list[str]) -> dict:
    fm = {
        "title": meta["title"],
        "slug": slug,
        "kind": "paper",
        "status": "draft",
        "created_at": today,
        "reviewed_at": None,
        "review_frequency": "never",
        "domains": [domain],
        "tags": meta.get("tags") or [],
        "source": {
            "type": "paper",
            "url": (f"https://arxiv.org/abs/{meta['arxiv_id']}" if meta.get("arxiv_id") else None),
            "pdf_url": (f"https://arxiv.org/pdf/{meta['arxiv_id']}" if meta.get("arxiv_id") else None),
            "pdf_path": pdf_path_rel,
        },
        "paper": {
            "authors": meta.get("authors") or [],
            "affiliations_summary": meta.get("affiliations_summary") or [],
            "year": meta.get("year"),
            "venue": meta.get("venue"),
            "venue_type": meta.get("venue_type"),
            "peer_reviewed": meta.get("peer_reviewed"),
            "doi": meta.get("doi"),
            "arxiv_id": meta.get("arxiv_id"),
            "isbn": meta.get("isbn"),
            "field": meta.get("field"),
            "paper_type": meta.get("paper_type"),
            "has_code": meta.get("has_code", False),
            "has_data": meta.get("has_data", False),
            "code_url": meta.get("code_url"),
            "data_url": meta.get("data_url"),
            "funding": meta.get("funding"),
            "conflicts_of_interest": meta.get("conflicts_of_interest"),
            "citations_at_ingest": None,
        },
        "conversion": {
            "tool": conv_tool,
            "tool_version": conv_version,
            "converted_at": today,
            "used_llm": False,
            "warnings": conv_warnings,
            "pages": pages,
        },
    }
    return fm

GUIDANCE_COMMENT = """<!--
This file holds the raw converted paper. Body below this comment is the
verbatim converter output: headings, equations (LaTeX where supported),
tables, figure captions. Do NOT add interpretation, summary, or commentary
here. Synthesis lives in a separate source-note doc that references this
paper via source_refs.
-->
"""

def render_doc(fm: dict, body: str) -> str:
    yaml_text = yaml.safe_dump(fm, sort_keys=False, allow_unicode=True, default_flow_style=False, width=10000).rstrip()
    return f"---\n{yaml_text}\n---\n\n{GUIDANCE_COMMENT}\n# {fm['title']}\n\n{body.lstrip()}"

# ---- main -----------------------------------------------------------------

def main() -> None:
    p = argparse.ArgumentParser()
    p.add_argument("pdf", help="path to a local PDF file")
    p.add_argument("--domain", default="brand-content-strategy")
    p.add_argument("--lab-root", default="/Users/edmundmitchell/Documents/Claude/Projects/EM Research Lab")
    p.add_argument("--converter", default="marker", choices=["pymupdf4llm", "marker"])
    args = p.parse_args()

    env = load_env()

    pdf_path = Path(args.pdf).expanduser().resolve()
    if not pdf_path.is_file():
        sys.exit(f"not a file: {pdf_path}")
    if pdf_path.suffix.lower() != ".pdf":
        sys.exit(f"not a PDF: {pdf_path}")

    lab_root = Path(args.lab_root).resolve()
    if not (lab_root / "knowledge-atlas").is_dir():
        sys.exit(f"lab root not scaffolded: {lab_root}")

    today = date.today().isoformat()

    # ---- Convert ----
    print(f"converting:  {pdf_path.name} ({args.converter})…")
    body_md, tool, version, pages, conv_warnings = convert_pdf(pdf_path, args.converter)
    print(f"  tool used: {tool} {version}")
    print(f"  pages:     {pages}")
    print(f"  chars:     {len(body_md)}")
    if conv_warnings:
        for w in conv_warnings:
            print(f"  warning:   {w}")

    head = body_md[:4000]
    tail = body_md[-2000:] if len(body_md) > 6000 else ""

    # ---- Extract metadata via agent ----
    print("loading paper-reader agent prompt…")
    prompt_template = load_agent_prompt(lab_root, "paper-reader-agent.md")
    print("calling claude…")
    meta = call_claude(env, prompt_template.format(
        domain=args.domain,
        filename=pdf_path.name,
        head=head,
        tail=tail,
    ))

    slug = meta["slug"]
    validate_slug(slug)
    print(f"slug:        {slug}")
    print(f"title:       {meta['title']}")
    print(f"authors:     {len(meta.get('authors') or [])}")

    # ---- Stage filesystem writes ----
    staging = Path(tempfile.mkdtemp(prefix="lab-ingest-pdf-"))
    print(f"staging:     {staging}")

    inbox_md   = lab_root / "inbox" / "proposed" / f"{slug}.md"
    inbox_pdf  = lab_root / "inbox" / "raw" / "papers" / f"{slug}.pdf"
    atlas_md   = lab_root / "knowledge-atlas" / "documents" / f"{slug}.md"
    atlas_pdf  = lab_root / "knowledge-atlas" / "raw" / "papers" / f"{slug}.pdf"

    for collision in (inbox_md, inbox_pdf, atlas_md, atlas_pdf):
        if collision.exists():
            shutil.rmtree(staging)
            sys.exit(f"collision: {collision.relative_to(lab_root)} already exists. Pick another slug or remove the file.")

    pdf_path_rel = str(inbox_pdf.relative_to(lab_root))
    fm = build_frontmatter(meta, slug, args.domain, today, pdf_path_rel, tool, version, pages, conv_warnings=conv_warnings)

    staged_md = staging / f"{slug}.md"
    staged_pdf = staging / f"{slug}.pdf"
    staged_md.write_text(render_doc(fm, body_md))
    shutil.copyfile(pdf_path, staged_pdf)

    # ---- Insert Supabase row ----
    row = {
        "slug": slug,
        "title": meta["title"],
        "body": staged_md.read_text(),
        "kind": "paper",
        "lab_zone": "inbox",
        "status": "draft",
        "source_refs": [],   # paper IS the source, not a reference to one
        "reviewed_at": None,
        "review_frequency": "never",
        "metadata": {
            "domains": [args.domain],
            "tags": meta.get("tags") or [],
            "arxiv_id": meta.get("arxiv_id"),
            "doi": meta.get("doi"),
            "year": meta.get("year"),
            "venue": meta.get("venue"),
            "paper_type": meta.get("paper_type"),
            "pdf_filename": pdf_path.name,
            "staged_at": datetime.now(timezone.utc).isoformat(),
        },
    }
    print("inserting reference_docs row…")
    try:
        ref_id = insert_reference_doc(env, row)
    except Exception as e:
        shutil.rmtree(staging)
        sys.exit(f"supabase insert failed: {e}")
    print(f"ref_id:      {ref_id}")

    # ---- Commit filesystem moves ----
    try:
        inbox_md.parent.mkdir(parents=True, exist_ok=True)
        inbox_pdf.parent.mkdir(parents=True, exist_ok=True)
        shutil.move(str(staged_md), str(inbox_md))
        shutil.move(str(staged_pdf), str(inbox_pdf))
    except Exception as e:
        delete_reference_doc_by_slug(env, slug)
        shutil.rmtree(staging, ignore_errors=True)
        # best-effort cleanup of partial moves
        for f in (inbox_md, inbox_pdf):
            f.unlink(missing_ok=True)
        sys.exit(f"filesystem move failed; rolled back Supabase row: {e}")
    finally:
        shutil.rmtree(staging, ignore_errors=True)

    print("\n✓ staged in inbox:")
    print(f"  {inbox_md.relative_to(lab_root)}")
    print(f"  {inbox_pdf.relative_to(lab_root)}")
    print(f"  reference_docs.id = {ref_id}  (lab_zone=inbox, status=draft)")
    print(f"\nReview the file. When ready, promote to atlas:")
    print(f"  lab-promote {slug}")

if __name__ == "__main__":
    main()
