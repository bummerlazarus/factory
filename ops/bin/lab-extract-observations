#!/usr/bin/env python3
"""
lab-extract-observations — read one source-note (from atlas), extract
structured observations, and write them to:

  - research/01-observations/<source-slug>.md   (markdown log, one bullet per obs)
  - public.observations rows in Supabase        (one row per observation)

An "observation" is a small, single-claim unit derived FROM the source-note.
Observations are atomic, kind-typed (pattern | claim | contradiction | gap |
distinction), and tagged with the source slug + domain. They feed the
compression cron (Phase 3) and the synthesis agent.

This is NOT the reading agent. It runs against an existing source-note in
the atlas, not a raw transcript.

Usage:
  lab-extract-observations <source-slug> [--lab-root PATH] [--dry-run]
"""
from __future__ import annotations
import argparse, json, os, re, sys, urllib.parse, urllib.request, urllib.error
from datetime import datetime, timezone, date
from pathlib import Path

import yaml

ENV_PATH = Path(os.environ.get("FACTORY_ENV", "/Users/edmundmitchell/factory/ops/.env"))
ANTHROPIC_MODEL = "claude-opus-4-7"
FRONTMATTER_RE = re.compile(r"\A---\s*\n(.*?)\n---\s*\n", re.DOTALL)


def load_env() -> dict:
    if not ENV_PATH.exists():
        sys.exit(f"env file not found: {ENV_PATH}")
    env = {}
    for line in ENV_PATH.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        env[k.strip()] = v.strip().strip('"').strip("'")
    for r in ("SUPABASE_URL", "SUPABASE_SERVICE_ROLE_KEY", "ANTHROPIC_API_KEY"):
        if not env.get(r):
            sys.exit(f"missing env: {r}")
    return env


def http(method, url, headers, body=None):
    data = None
    if body is not None:
        data = body if isinstance(body, (bytes, bytearray)) else json.dumps(body).encode()
    req = urllib.request.Request(url, data=data, method=method, headers=headers)
    try:
        with urllib.request.urlopen(req) as resp:
            return resp.status, resp.read()
    except urllib.error.HTTPError as e:
        return e.code, e.read()


def sb_headers(env):
    return {
        "apikey": env["SUPABASE_SERVICE_ROLE_KEY"],
        "Authorization": f"Bearer {env['SUPABASE_SERVICE_ROLE_KEY']}",
        "Content-Type": "application/json",
    }


PROMPT_RE = re.compile(r"## Prompt\b.*?\n```[^\n]*\n(.*?)\n```", re.DOTALL)

def load_agent_prompt(lab_root: Path, agent_filename: str) -> str:
    path = lab_root / "research" / "04-agent-instructions" / agent_filename
    if not path.is_file():
        sys.exit(f"agent instructions not found: {path}")
    m = PROMPT_RE.search(path.read_text())
    if not m:
        sys.exit(f"no ## Prompt fenced block in {path}")
    return m.group(1)


def call_claude(env, prompt):
    body = {
        "model": ANTHROPIC_MODEL,
        "max_tokens": 4096,
        "messages": [{"role": "user", "content": prompt}],
    }
    headers = {
        "x-api-key": env["ANTHROPIC_API_KEY"],
        "anthropic-version": "2023-06-01",
        "content-type": "application/json",
    }
    status, raw = http("POST", "https://api.anthropic.com/v1/messages", headers, body)
    if status != 200:
        sys.exit(f"anthropic call failed ({status}): {raw[:500]!r}")
    resp = json.loads(raw)
    text = "".join(b["text"] for b in resp["content"] if b["type"] == "text").strip()
    if text.startswith("```"):
        text = re.sub(r"^```(?:json)?\s*|\s*```$", "", text, flags=re.DOTALL)
    parsed = json.loads(text)
    if "error" in parsed:
        sys.exit(f"observation extractor declined: {parsed['error']}")
    return parsed["observations"]


def insert_observations(env, observations, slug, domain):
    headers = {**sb_headers(env), "Prefer": "return=representation"}
    rows = []
    for o in observations:
        rows.append({
            "kind": o["kind"],
            "body": o["body"],
            "confidence": (o.get("confidence") or "medium")[:1].lower() if False else None,  # see below
            "metadata": {
                "source_refs": [slug],
                "domain": domain,
                "tags": o.get("tags") or [],
                "confidence": o.get("confidence") or "medium",
                "extracted_at": datetime.now(timezone.utc).isoformat(),
                "extracted_by": "lab-extract-observations",
            },
            "compression_safe": False,
            "ready_for_promotion": False,
        })
    # observations.confidence is numeric in the schema; we keep our string in metadata
    for r in rows:
        r.pop("confidence", None)
    status, body = http("POST", f"{env['SUPABASE_URL']}/rest/v1/observations",
                        headers, body=rows)
    if status not in (200, 201):
        sys.exit(f"observations insert failed ({status}): {body[:500]!r}")
    return json.loads(body)


def render_observation_log(observations, slug, source_title, domain, today):
    out = [
        "---",
        f'title: "Observations: {source_title}"',
        f"slug: obs-{slug}",
        "kind: observation-log",
        "status: current",
        f"created_at: {today}",
        f"source_refs:",
        f"  - {slug}",
        "domains:",
        f"  - {domain}",
        "---",
        "",
        f"# Observations from `{slug}`",
        "",
        f"_{len(observations)} observation(s) extracted by `lab-extract-observations` on {today}._",
        "",
    ]
    for o in observations:
        out.append(f"- **[{o['kind']}]** {o['body']}")
        meta_bits = []
        conf = o.get("confidence")
        if conf:
            meta_bits.append(f"confidence: {conf}")
        tags = o.get("tags") or []
        if tags:
            meta_bits.append("tags: " + ", ".join(tags))
        if meta_bits:
            out.append(f"  - _{' · '.join(meta_bits)}_")
    out.append("")
    return "\n".join(out)


def main():
    p = argparse.ArgumentParser()
    p.add_argument("slug", help="source-note slug (must exist in knowledge-atlas/documents/)")
    p.add_argument("--lab-root", default="/Users/edmundmitchell/Documents/Claude/Projects/EM Research Lab")
    p.add_argument("--dry-run", action="store_true")
    args = p.parse_args()

    lab_root = Path(args.lab_root).resolve()
    src_path = lab_root / "knowledge-atlas" / "documents" / f"{args.slug}.md"
    if not src_path.is_file():
        sys.exit(f"source-note not found: {src_path.relative_to(lab_root)}")

    text = src_path.read_text()
    m = FRONTMATTER_RE.match(text)
    if not m:
        sys.exit("source-note has no frontmatter")
    fm = yaml.safe_load(m.group(1)) or {}
    if fm.get("kind") != "source-note":
        sys.exit(f"file is kind={fm.get('kind')!r}, expected source-note")
    domains = fm.get("domains") or []
    if not domains:
        sys.exit("source-note has no domain")
    domain = domains[0]
    title = fm.get("title", args.slug)

    print(f"slug:    {args.slug}")
    print(f"title:   {title}")
    print(f"domain:  {domain}")

    env = load_env()
    print("loading agent instructions…")
    prompt_template = load_agent_prompt(lab_root, "observation-extractor.md")
    print("calling claude…")
    observations = call_claude(env, prompt_template.format(
        domain=domain, slug=args.slug, source_note=text,
    ))
    print(f"observations: {len(observations)}")

    today = date.today().isoformat()
    log_path = lab_root / "research" / "01-observations" / f"{args.slug}.md"
    log_text = render_observation_log(observations, args.slug, title, domain, today)

    if args.dry_run:
        print("\n[dry-run]\n" + log_text)
        return

    if log_path.exists():
        sys.exit(f"collision: {log_path.relative_to(lab_root)} already exists. Delete it first.")
    log_path.parent.mkdir(parents=True, exist_ok=True)
    log_path.write_text(log_text)

    inserted = insert_observations(env, observations, args.slug, domain)
    obs_ids = [r["id"] for r in inserted]

    print(f"\n✓ wrote {len(observations)} observations:")
    print(f"  {log_path.relative_to(lab_root)}")
    print(f"  Supabase observations: {len(obs_ids)} row(s)")


if __name__ == "__main__":
    main()
