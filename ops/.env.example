# ops/.env — secrets for ad-hoc ops scripts at the factory root.
# Copy to ops/.env and fill in values. This file (.env.example) is tracked;
# .env is gitignored.

# Circle (community platform)
CIRCLE_ADMIN_API_TOKEN=
CIRCLE_COMMUNITY_SLUG=zpm

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase Personal Access Token — for CLI deploys / Management API
# Get one from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# Auth token for custom Edge Functions (capture, youtube-ingest, etc.)
CAPTURE_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# Pinecone (legacy — being retired; see 06-handoffs for status)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=gravity-claw

# Google / YouTube
GOOGLE_API_KEY=
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# Notion
NOTION_API_KEY=

# Firecrawl (primary web research tool)
FIRECRAWL_API_KEY=

# OpenRouter / OpenAI
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=
TELEGRAM_CHAT_ID=

# beehiiv
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# ElevenLabs (optional)
ELEVENLABS_API_KEY=

# Instagram / Meta (optional — currently abandoned, see W5.4)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
